{
  "name": "@opik/opik-openclaw",
  "version": "0.1.5",
  "description": "OpenClaw Opik exporter — sends LLM traces to Opik",
  "type": "module",
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=11"
  },
  "scripts": {
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "vitest run src/**/*.e2e.test.ts",
    "smoke": "vitest run src/plugin.smoke.test.ts"
  },
  "dependencies": {
    "@clack/prompts": "^1.0.1",
    "opik": "^1.10.22"
  },
  "peerDependencies": {
    "openclaw": ">=2026.3.1"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "files": [
    "index.ts",
    "src/configure.ts",
    "src/service.ts",
    "src/types.ts",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE"
  ],
  "openclaw": {
    "extensions": [
      "./index.ts"
    ]
  }
}
