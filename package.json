{
  "name": "@opik/opik-openclaw",
  "version": "0.2.8",
  "license": "Apache-2.0",
  "description": "OpenClaw trace exporter — persists LLM traces to local DuckDB (TruLens-compatible events + audit tables)",
  "repository": {
    "type": "git",
    "url": "https://github.com/comet-ml/opik-openclaw"
  },
  "type": "module",
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=10"
  },
  "scripts": {
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "vitest run src/**/*.e2e.test.ts",
    "smoke": "vitest run src/plugin.smoke.test.ts"
  },
  "dependencies": {
    "@clack/prompts": "^1.0.1",
    "@duckdb/node-api": "^1.5.0-r.1",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "openclaw": ">=2026.3.2"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "files": [
    "index.ts",
    "src/register-opik-hooks.ts",
    "src/configure.ts",
    "src/service.ts",
    "src/opik-trace-exporter.ts",
    "src/service/constants.ts",
    "src/service/helpers.ts",
    "src/service/payload-sanitizer.ts",
    "src/service/media.ts",
    "src/service/attachment-uploader.ts",
    "src/service/hook-enter-log.ts",
    "src/service/instrument-plugin-api.ts",
    "src/service/hooks/llm.ts",
    "src/service/hooks/tool.ts",
    "src/service/hooks/subagent.ts",
    "src/storage/duckdb-pool.ts",
    "src/storage/duckdb-trulens-writer.ts",
    "src/local-tracer.ts",
    "src/shared-opik-runtime.ts",
    "src/types.ts",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE",
    "scripts/verify-duckdb-events.py"
  ],
  "openclaw": {
    "extensions": [
      "./index.ts"
    ]
  }
}
